/**
 * Types for async transaction signing feature.
 *
 * Async signing allows the wallet modal to close immediately after user confirmation,
 * with signing happening in the background. Events are emitted to notify the consuming
 * app of progress. Keeping track is also possible through the useWaapTransaction hook.
 */
/**
 * Event types emitted during async signing lifecycle
 */
export type AsyncEventType = 'waap_sign_pending' | 'waap_2fa_required' | 'waap_sign_complete' | 'waap_sign_failed' | 'waap_tx_pending' | 'waap_tx_confirmed' | 'waap_tx_failed';
/**
 * Emitted when async signing starts (after user confirms)
 */
export interface AsyncSignPendingEvent {
    pendingTxId: string;
    txRequest: {
        to?: string;
        from?: string;
        value?: string;
        data?: string;
        chainId?: number;
    };
}
/**
 * Emitted when 2FA is required for high-risk transactions
 * Modal will re-open automatically for 2FA
 */
export interface Async2faRequiredEvent {
    pendingTxId: string;
}
/**
 * Emitted when signing completes (before broadcasting for transactions)
 * - For eth_sendTransaction/eth_signTransaction: Contains both signature and serializedTx
 * - For message signing (personal_sign, eth_signTypedData_v4): Contains signature only, serializedTx is null
 */
export interface AsyncSignCompleteEvent {
    pendingTxId: string;
    signature: string;
    serializedTx: string | null;
}
/**
 * Emitted when an error occurs during signing
 */
export interface AsyncSignFailedEvent {
    pendingTxId: string;
    error: string;
}
/**
 * Emitted when transaction has been broadcast and is pending confirmation
 * Only emitted for eth_sendTransaction (not eth_signTransaction or message signing)
 */
export interface AsyncTxPendingEvent {
    pendingTxId: string;
    txHash: string;
}
/**
 * Emitted when transaction is confirmed on-chain
 * Only emitted for eth_sendTransaction (not eth_signTransaction)
 */
export interface AsyncTxConfirmedEvent {
    pendingTxId: string;
    txHash: string;
    receipt: {
        blockNumber: number;
        blockHash: string;
        transactionHash: string;
        status: 'success' | 'reverted';
        gasUsed: bigint;
    };
}
/**
 * Emitted when an error occurs during broadcast or confirmation
 */
export interface AsyncTxFailedEvent {
    pendingTxId: string;
    error: string;
    stage: 'broadcast' | 'confirmation';
}
/**
 * Union type for all async signing events
 */
export type AsyncEvent = AsyncSignPendingEvent | Async2faRequiredEvent | AsyncSignCompleteEvent | AsyncSignFailedEvent | AsyncTxPendingEvent | AsyncTxConfirmedEvent | AsyncTxFailedEvent;
/**
 * Response returned when asyncSigning=true
 */
export interface AsyncTxResponse {
    pendingTxId: string;
    status: 'pending';
}
/**
 * Options passed from SDK to iframe with transaction requests
 */
export interface SilkOptions {
    asyncSigning: boolean;
}
