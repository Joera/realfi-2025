{
  "name": "@holonym-foundation/mishtiwasm",
  "version": "0.3.2",
  "description": "Mishti Network SDK for browser and Node.js",
  "exports": {
    "types": "./pkg/esm/mishtiwasm.d.ts",
    "require": "./pkg/cjs/mishtiwasm.js",
    "default": "./pkg/esm/mishtiwasm.js"
  },
  "main": "./dist/cjs/mishtiwasm.js",
  "module": "./dist/esm/mishtiwasm.js",
  "author": "",
  "license": "",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build-cjs && npm run build-esm",
    "build-cjs": "wasm-pack build --target nodejs --out-dir ./pkg/cjs && rm ./pkg/cjs/.gitignore",
    "build-esm": "wasm-pack build --target web --out-dir ./pkg/esm && rm ./pkg/esm/.gitignore"
  },
  "files": [
    "/pkg"
  ]
}
