{
  "name": "@human.tech/waap-interface-core",
  "version": "0.2.0",
  "description": "Types for the Silk wallet interface",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "author": "",
  "license": "",
  "private": false,
  "files": [
    "/dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "eslint": "8.38.0",
    "eslint-plugin-jest": "^27.2.3",
    "typescript": "^5.0.4",
    "eslint-config-custom": "0.0.0"
  },
  "dependencies": {
    "crypto-js": "^4.2.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && sh scripts/prepare-package-json.sh",
    "dev": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && sh scripts/prepare-package-json.sh -w",
    "lint-check": "(bash ../../scripts/list-src-changes.sh) | xargs eslint --ext .ts,.tsx",
    "lint-fix": "(bash ../../scripts/list-src-changes.sh) | xargs eslint --fix --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  }
}