  },
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/events": "^3.0.0",
    "@types/node": "18.15.11",
    "@types/react": "^18.0.0",
    "eslint": "8.38.0",
    "eslint-plugin-jest": "^27.2.3",
