{"version":3,"sources":["../src/cli.ts","../package.json","../src/utils/files.ts","../src/index.ts"],"sourcesContent":["#! /usr/bin/env node\n\nimport {Command, Option} from 'commander';\nimport pkg from '../package.json';\nimport {copyDefaults} from '.';\nconst name = pkg.name;\n\nconst program = new Command();\nprogram\n\t.name(name)\n\t.version(pkg.version)\n\t.usage(`[dirs|files...]`)\n\t.argument(`[dirs|files...]`)\n\t.description('copy default files to their respective filename')\n\t.action((foldersOrFiles: string[]) => {\n\t\tcopyDefaults({foldersOrFiles: foldersOrFiles || ['.']});\n\t});\n\nprogram.parse();\n","{\n\t\"name\": \"set-defaults\",\n\t\"version\": \"0.0.5\",\n\t\"description\": \"copy default files to their actual file name\",\n\t\"publishConfig\": {\n\t\t\"access\": \"public\"\n\t},\n\t\"type\": \"module\",\n\t\"main\": \"dist/index.cjs\",\n\t\"module\": \"dist/index.js\",\n\t\"types\": \"dist/index.d.ts\",\n\t\"bin\": {\n\t\t\"set-defaults\": \"dist/cli.cjs\"\n\t},\n\t\"devDependencies\": {\n\t\t\"@types/node\": \"^18.15.5\",\n\t\t\"rimraf\": \"^4.4.1\",\n\t\t\"tsup\": \"^6.7.0\",\n\t\t\"typescript\": \"^4.9.5\"\n\t},\n\t\"dependencies\": {\n\t\t\"commander\": \"^10.0.0\"\n\t},\n\t\"scripts\": {\n\t\t\"build\": \"rimraf dist && tsup --entry src/index.ts --entry src/cli.ts --dts --format esm,cjs\"\n\t}\n}\n","import fs from 'node:fs';\nimport path from 'node:path';\n\nexport function copyUnlessExists(from: string, to: string): boolean {\n\tif (!fs.existsSync(to)) {\n\t\tif (fs.existsSync(from)) {\n\t\t\tfs.copyFileSync(from, to);\n\t\t\treturn true;\n\t\t}\n\t}\n\treturn false;\n}\n\nexport function writeIfNotExists(p: string, content: string): boolean {\n\tif (!fs.existsSync(p)) {\n\t\tfs.writeFileSync(p, content);\n\t\treturn true;\n\t}\n\treturn false;\n}\n\nexport function copyFromDefault(p: string): boolean {\n\treturn copyUnlessExists(`${p}.default`, p);\n}\n\nexport function copyFromAllDefault(folderOrFile: string): boolean {\n\tif (fs.existsSync(folderOrFile)) {\n\t\tif (fs.statSync(folderOrFile).isDirectory()) {\n\t\t\tconst files = fs\n\t\t\t\t.readdirSync(folderOrFile)\n\t\t\t\t.filter((v) => v.endsWith('.default'))\n\t\t\t\t.map((v) => path.join(folderOrFile, v.slice(0, v.length - 8)));\n\n\t\t\treturn files.map(copyFromDefault).reduce((prev, curr) => prev || curr, false);\n\t\t} else {\n\t\t\tif (!folderOrFile.endsWith('.default')) {\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\treturn copyFromDefault(folderOrFile.slice(0, folderOrFile.length - 8));\n\t\t}\n\t} else {\n\t\treturn false;\n\t}\n}\n","import {copyFromAllDefault} from './utils/files';\n\nexport type Config = {\n\tfoldersOrFiles?: string[];\n};\n\ntype ResolvedConfig = Config & {foldersOrFiles: string[]};\n\nexport async function copyDefaults(config: Config) {\n\tconst resolvedConfig: ResolvedConfig = {foldersOrFiles: ['.'], ...config};\n\n\tlet anyChanges = false;\n\tfor (const folder of resolvedConfig.foldersOrFiles) {\n\t\tanyChanges = copyFromAllDefault(folder) || anyChanges;\n\t}\n\n\t// TODO option to show message ?\n\t// if (anyChanges) {\n\t// \tconsole.log('setting up defaults...');\n\t// }\n}\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAEA,uBAA8B;;;ACF9B;AAAA,EACC,MAAQ;AAAA,EACR,SAAW;AAAA,EACX,aAAe;AAAA,EACf,eAAiB;AAAA,IAChB,QAAU;AAAA,EACX;AAAA,EACA,MAAQ;AAAA,EACR,MAAQ;AAAA,EACR,QAAU;AAAA,EACV,OAAS;AAAA,EACT,KAAO;AAAA,IACN,gBAAgB;AAAA,EACjB;AAAA,EACA,iBAAmB;AAAA,IAClB,eAAe;AAAA,IACf,QAAU;AAAA,IACV,MAAQ;AAAA,IACR,YAAc;AAAA,EACf;AAAA,EACA,cAAgB;AAAA,IACf,WAAa;AAAA,EACd;AAAA,EACA,SAAW;AAAA,IACV,OAAS;AAAA,EACV;AACD;;;AC1BA,qBAAe;AACf,uBAAiB;AAEV,SAAS,iBAAiB,MAAc,IAAqB;AACnE,MAAI,CAAC,eAAAA,QAAG,WAAW,EAAE,GAAG;AACvB,QAAI,eAAAA,QAAG,WAAW,IAAI,GAAG;AACxB,qBAAAA,QAAG,aAAa,MAAM,EAAE;AACxB,aAAO;AAAA,IACR;AAAA,EACD;AACA,SAAO;AACR;AAUO,SAAS,gBAAgB,GAAoB;AACnD,SAAO,iBAAiB,GAAG,aAAa,CAAC;AAC1C;AAEO,SAAS,mBAAmB,cAA+B;AACjE,MAAI,eAAAC,QAAG,WAAW,YAAY,GAAG;AAChC,QAAI,eAAAA,QAAG,SAAS,YAAY,EAAE,YAAY,GAAG;AAC5C,YAAM,