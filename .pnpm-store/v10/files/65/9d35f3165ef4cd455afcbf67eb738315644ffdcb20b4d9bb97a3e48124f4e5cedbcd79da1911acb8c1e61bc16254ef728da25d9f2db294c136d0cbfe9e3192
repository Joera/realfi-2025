/* tslint:disable */
/* eslint-disable */
export function enable_errors(): void;
/**
 * Returns a tuple of two strings: the ephemeral private key and the signature of the conditions contract
 */
export function generate_ephemeral_key_and_sign_conditions_with_it(conditions_contract: string): string;
export function msg_to_point(msg: Uint8Array): string;
/**
 * * `method` - Either OPRFSecp256k1 or DecryptBabyJubJub
 * * `address` - Address of the user
 */
export function get_user_state(method: string, address: string): Promise<string>;
/**
 * Utility function to serialize and sign a request. Helpful because
 * there is no js implementation of bincode.
 * * `request` - Must be JSON stringified RequestToNetwork
 */
export function sign_request_to_network(request: string, private_key: string): Promise<string>;
/**
 * The x and y values in ciphertext must be decimal strings.
 *
 * * `mishti_user_privkey` - Private key of the account with Mishti decryption credits
 * * `ciphertext` - ElGamal ciphertext. JSON string with the following structure:
 *                 { c1: { x: string, y: string }, c2: { x: string, y: string } }
 * * `conditions_contract` - Address of the smart contract signed by the private
 *                           key corresponding to c1 in ciphertext
 * * `sig` - Schnorr signature. JSON string with the following structure:
 *           { R: string, s: string }
 */
export function decrypt(mishti_user_privkey: string, ciphertext: string, conditions_contract: string, sig: string): Promise<string>;
export function new_mask(): any;
/**
 * Computes proof of mask and a request to the network with the JWT and its proof of the mask
 * The request will not be complete because the epoch, request number, and signature are empty or zero.
 * Depending on who is signing the request, these need to be filled in or corrected before sending it to the network.
 */
export function make_jwt_request(secret_mask: string, jwt: string): Promise<any>;
export function unmask_and_hash_to_field_secp256k1(mask: string, point: string): string;
export function request_from_signer(input: string, method: string, signer_url: string): Promise<string>;
export function generate_oprf(private_key: string | null | undefined, input: string | null | undefined, method: string, rpc_url: string): Promise<string>;
