import { ethers } from 'ethers';
import { PriceFeedInfo } from './apis/highLevelApis';
export interface LitChainClientContext {
    rpcUrl: string;
    networkName: string;
    provider?: ethers.providers.Provider;
}
export interface LitContractSetup {
    [contractName: string]: ethers.Contract;
}
export interface ContractDeploymentInfo {
    name: string;
    address: string;
    abi: any[];
}
export interface NetworkContractDeployments {
    [contractName: string]: ContractDeploymentInfo;
}
/**
 * Interface representing the structure of connection information
 */
export interface ConnectionInfo {
    epochInfo: {
        epochLength: number;
        number: number;
        endTime: number;
        retries: number;
        timeout: number;
    };
    epochState: {
        currentNumber: number;
        startTime: number;
    };
    minNodeCount: number;
    bootstrapUrls: string[];
    priceFeedInfo: PriceFeedInfo;
}
